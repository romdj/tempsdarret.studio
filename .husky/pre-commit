#!/bin/sh
# Pre-commit quality gates: lint + unit tests (fast, infra-free).
# Component/integration/contract tiers need Mongo/Kafka and run in CI, not here.

echo "🔍 Running pre-commit quality checks..."

# 1. Lint - fail the commit if linting fails
pnpm run lint || {
  echo "❌ Lint failed! Fix errors before committing."
  exit 1
}

# 2. Unit tests - fail the commit if any unit test fails
echo "🧪 Running unit tests..."
pnpm run test:unit || {
  echo "❌ Unit tests failed! Fix them before committing."
  exit 1
}

echo "✅ Pre-commit checks passed!"
