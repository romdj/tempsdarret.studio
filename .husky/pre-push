#!/bin/sh
# Pre-push quality gates — mirror CI's "Quality • Lint & Type Check" + unit tests.
#
# Build the workspace libraries FIRST: the type-aware lint rules and tsc resolve
# @tempsdarret/* through the compiled dist/, so a STALE local dist/ shadows the
# current source and makes local lint/type-check diverge from CI (which always
# builds from a clean checkout). Rebuilding first keeps this gate equivalent to CI.

echo "🧪 Running pre-push quality checks..."

# 1. Build workspace libraries (refresh dist so lint/type-check see current types)
echo "🔨 Step 1/4: Building workspace libraries..."
npm run build || {
  echo "❌ Build failed! Fix errors before pushing."
  exit 1
}

# 2. Lint
echo "📋 Step 2/4: Linting..."
npm run lint || {
  echo "❌ Lint failed! Fix errors before pushing."
  exit 1
}

# 3. Type check
echo "🔍 Step 3/4: Type checking..."
npm run check || {
  echo "❌ Type check failed! Fix errors before pushing."
  exit 1
}

# 4. Unit tests (infra-free gate; component/integration/contract run in CI)
echo "🧪 Step 4/4: Running unit tests..."
npm run test:unit || {
  echo "❌ Unit tests failed! Fix them before pushing."
  exit 1
}

echo "✅ Pre-push checks passed! Safe to push."
