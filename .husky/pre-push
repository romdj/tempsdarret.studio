#!/bin/sh
# Pre-push quality gates — mirror CI's "Quality • Lint & Type Check" + unit tests.
#
# Clean + rebuild the workspace libraries FIRST: the type-aware lint rules and tsc
# resolve @tempsdarret/* through the compiled dist/, so a STALE or orphaned local
# dist/ shadows current source and makes local lint/type-check diverge from CI
# (which always builds from a clean checkout). A plain rebuild can leave orphaned
# artifacts, so we clean the lib dist first — keeping this gate equivalent to CI.

echo "🧪 Running pre-push quality checks..."

# 1. Clean + rebuild workspace libraries (dist/ must reflect CURRENT source)
echo "🔨 Step 1/4: Clean + rebuild workspace libraries..."
rm -rf packages/models/dist packages/models/tsp-output packages/shared/dist
pnpm run build || {
  echo "❌ Build failed! Fix errors before pushing."
  exit 1
}

# 2. Lint
echo "📋 Step 2/4: Linting..."
pnpm run lint || {
  echo "❌ Lint failed! Fix errors before pushing."
  exit 1
}

# 3. Type check
echo "🔍 Step 3/4: Type checking..."
pnpm run check || {
  echo "❌ Type check failed! Fix errors before pushing."
  exit 1
}

# 4. Unit tests (infra-free gate; component/integration/contract run in CI)
echo "🧪 Step 4/4: Running unit tests..."
pnpm run test:unit || {
  echo "❌ Unit tests failed! Fix them before pushing."
  exit 1
}

echo "✅ Pre-push checks passed! Safe to push."
