{
  "name": "@tempsdarret/file-service",
  "version": "0.1.0",
  "description": "Large file management, multi-resolution processing, and archive generation service",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run tests/integration",
    "test:unit": "vitest run tests/services tests/handlers",
    "lint": "eslint src",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/multipart": "^8.0.0",
    "@tempsdarret/events": "workspace:*",
    "archiver": "^7.0.1",
    "sharp": "^0.33.0",
    "ts-exif-parser": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "mongodb-memory-server": "^9.1.0",
    "supertest": "^6.3.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  }
}