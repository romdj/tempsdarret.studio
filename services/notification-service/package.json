{
  "name": "@tempsdarret/notification-service",
  "version": "0.1.0",
  "description": "Event-driven email notifications service with Resend.dev and Payload CMS",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "payload": "tsx src/payload/server.ts",
    "payload:dev": "tsx watch src/payload/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@payloadcms/bundler-webpack": "^1.0.0",
    "@payloadcms/db-mongodb": "^1.5.0",
    "@payloadcms/richtext-slate": "^1.5.0",
    "@tempsdarret/events": "workspace:*",
    "@tempsdarret/shared": "workspace:*",
    "bullmq": "^5.0.0",
    "handlebars": "^4.7.0",
    "ioredis": "^5.3.0",
    "juice": "^10.0.0",
    "kafkajs": "^2.2.0",
    "payload": "^2.24.0",
    "resend": "^3.2.0"
  },
  "devDependencies": {
    "@types/handlebars": "^4.1.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "mongodb-memory-server": "^9.1.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  }
}