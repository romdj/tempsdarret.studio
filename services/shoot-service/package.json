{
  "name": "@tempsdarret/shoot-service",
  "version": "0.1.0",
  "description": "Photography shoot lifecycle management and client gallery service",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit --passWithNoTests",
    "test:component": "vitest run tests/component --passWithNoTests",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "test:contract": "vitest run tests/contract --passWithNoTests",
    "lint": "eslint src",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@tempsdarret/shared": "workspace:*",
    "tsx": "^4.20.3",
    "@tempsdarret/events": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "mongodb-memory-server": "^9.1.0",
    "@testcontainers/mongodb": "^10.13.0",
    "@testcontainers/kafka": "^10.13.0",
    "testcontainers": "^10.13.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.12.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  }
}
